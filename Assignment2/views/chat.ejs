<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= room.name %></title>
  <link rel="stylesheet" href="/css/styles.css">
</head>
<body class="page">
  <div class="navbar">
    <span>Logged in as: <strong><%= username %></strong></span>
    <a href="/logout" class="btn btn-secondary" style="padding: 8px 20px; margin: 0;">Logout</a>
  </div>

  <div class="page-container">
    <h1 style="margin-bottom: 5px;"><%= room.name %></h1>
    <p style="margin-bottom: 20px;">
      <a href="/groups/<%= room.room_id %>/invite"> Invite People</a>
      &nbsp;|&nbsp;
      <a href="/groups">← Back to Chats</a>
    </p>

    <% if (messages.length === 0) { %>
      <p style="color: rgba(255,255,255,0.5);">No messages yet. Say hello!</p>
    <% } %>


    <% let dividerShown = false; %>
<% messages.forEach(msg => { %>
  <% if (!dividerShown && msg.message_id > lastReadMessageId) { %>
    <div style="display:flex; align-items:center; margin: 15px 0;">
      <div style="flex:1; height:1px; background:rgba(255,100,100,0.6);"></div>
      <span style="margin: 0 10px; color:rgba(255,100,100,0.9); font-size:0.85rem; white-space:nowrap;">New Messages</span>
      <div style="flex:1; height:1px; background:rgba(255,100,100,0.6);"></div>
    </div>
    <% dividerShown = true; %>
  <% } %>
  <div class="message-card">
    <span class="message-username"><%= msg.username %></span>
    <span class="message-time"><%= new Date(msg.sent_datetime).toLocaleString() %></span>
    <p class="message-text"><%= msg.text %></p>
    <div>
      <% reactions.filter(r => r.message_id === msg.message_id).forEach(r => { %>
        <span class="reaction-badge"><%= r.symbol %> <%= r.count %></span>
      <% }) %>
      <form action="/groups/<%= room.room_id %>/react" method="POST" style="display:inline">
        <input type="hidden" name="message_id" value="<%= msg.message_id %>">
        <select name="emoji_id" style="background:rgba(255,255,255,0.1); color:white; border:1px solid rgba(255,255,255,0.2); border-radius:8px; padding:4px 8px;">
          <% emojis.forEach(e => { %>
            <option value="<%= e.emoji_id %>"><%= e.symbol %> <%= e.name %></option>
          <% }) %>
        </select>
        <button type="submit" class="btn" style="padding: 5px 12px; margin: 0;">React</button>
      </form>
    </div>
  </div>
<% }) %>

    <form action="/groups/<%= room.room_id %>/message" method="POST" class="send-form">
      <input type="text" name="text" placeholder="Type your message here..." required>
      <button type="submit" class="btn">Send</button>
    </form>
  </div>
</body>
</html>